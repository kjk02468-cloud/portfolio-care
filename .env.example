# Postgres connection string (e.g. from Neon: https://neon.tech).
# Local dev can also point at a local Postgres.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js secret. Generate one with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Public site URL in production (e.g. https://your-app.vercel.app). Local dev can omit.
AUTH_URL="http://localhost:3000"

# Comma-separated emails that should be treated as admins. A matching account is
# promoted to ADMIN automatically on login (no manual SQL needed). Register the
# account first, then log in.
ADMIN_EMAILS=""

# Optional: real-time quotes via Finnhub (https://finnhub.io — free tier).
# When unset, the app falls back to deterministic mock quotes so it runs offline.
FINNHUB_API_KEY=""

# Optional: historical prices + quarterly financials via Financial Modeling Prep
# (https://financialmodelingprep.com — free tier covers most of this). Feeds the
# G-value automation pipeline: G4 (52-week drawdown), 차트·수급 card, and the G3
# free proxy (earnings surprise + revenue-YoY acceleration). When unset, the
# pipeline runs on deterministic mock history so it works offline.
FMP_API_KEY=""
