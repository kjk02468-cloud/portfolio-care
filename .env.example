# Postgres connection string (e.g. from Neon: https://neon.tech).
# Local dev can also point at a local Postgres.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js secret. Generate one with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Public site URL in production (e.g. https://your-app.vercel.app). Local dev can omit.
AUTH_URL="http://localhost:3000"

# Optional: real-time quotes via Finnhub (https://finnhub.io — free tier).
# When unset, the app falls back to deterministic mock quotes so it runs offline.
FINNHUB_API_KEY=""
