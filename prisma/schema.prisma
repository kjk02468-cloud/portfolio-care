// Prisma schema for the portfolio management dashboard.
// SQLite for local development; swap `provider`/`url` for Postgres in production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUBSCRIBER
  ADMIN
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String
  role         UserRole     @default(SUBSCRIBER)
  createdAt    DateTime     @default(now())
  portfolios   Portfolio[]
  watchlist    WatchlistItem[]
  posts        AnalysisPost[]
}

model Portfolio {
  id           String        @id @default(cuid())
  userId       String
  name         String
  baseCurrency String        @default("USD")
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  snapshots    Snapshot[]

  @@index([userId])
}

enum TransactionSide {
  BUY
  SELL
}

model Transaction {
  id          String          @id @default(cuid())
  portfolioId String
  symbol      String
  name        String?
  assetType   String          @default("STOCK")
  side        TransactionSide @default(BUY)
  quantity    Float
  price       Float
  fee         Float           @default(0)
  tradedAt    DateTime        @default(now())
  createdAt   DateTime        @default(now())
  portfolio   Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([symbol])
}

// Periodic total-value snapshots used to render the portfolio value trend chart.
model Snapshot {
  id          String    @id @default(cuid())
  portfolioId String
  totalValue  Float
  totalCost   Float
  takenAt     DateTime  @default(now())
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

// ── JACK1 LENS: shared analysis skeleton ─────────────────────────────────────
// The five "lenses" are NOT separate models/pages — they are the `lensType`
// value on a single AnalysisPost. Lens-specific structured fields (lens_fields)
// arrive in a later phase and are intentionally omitted here (Phase 0).

// A tradeable instrument analysts tag posts with; ticker is the join key to a
// subscriber's holdings (derived from their transactions).
model Stock {
  id        String         @id @default(cuid())
  ticker    String         @unique
  name      String
  industry  String?
  sector    String?
  createdAt DateTime       @default(now())
  posts     AnalysisPost[]
}

enum LensType {
  earnings
  valuechain
  macro
  news
  financials
}

enum PostStatus {
  draft
  published
}

// The single unit of published analysis. `stocks` is the ticker_tags relation.
model AnalysisPost {
  id          String     @id @default(cuid())
  title       String
  body        String     // markdown
  lensType    LensType
  status      PostStatus @default(draft)
  themeTags   String?    // comma-separated; browsing UI arrives in a later phase
  authorId    String
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  stocks      Stock[]    // ticker_tags (many-to-many)

  @@index([status, publishedAt])
  @@index([lensType])
}
